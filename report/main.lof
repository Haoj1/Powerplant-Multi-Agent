\contentsline {figure}{\numberline {5.1}{\ignorespaces Evaluation summary: scenario runs, detection rate, diagnosis accuracy, healthy false positive rate, fault scenario detection rate.}}{55}{figure.caption.33}%
\contentsline {figure}{\numberline {5.2}{\ignorespaces Alert detection rate by signal (\%).}}{56}{figure.caption.35}%
\contentsline {figure}{\numberline {5.3}{\ignorespaces Diagnosis accuracy by root cause (\%).}}{57}{figure.caption.37}%
\contentsline {figure}{\numberline {5.4}{\ignorespaces Confusion matrix: expected (rows) vs.\ predicted (columns).}}{58}{figure.caption.38}%
\contentsline {figure}{\numberline {5.5}{\ignorespaces Scenario matrix: detection rate vs.\ diagnosis accuracy per fault scenario.}}{58}{figure.caption.39}%
\contentsline {figure}{\numberline {5.6}{\ignorespaces Steps and tokens: correct vs.\ incorrect diagnoses.}}{59}{figure.caption.40}%
\contentsline {figure}{\numberline {5.7}{\ignorespaces Average token usage by scenario (k tokens).}}{59}{figure.caption.41}%
